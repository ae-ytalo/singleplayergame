<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Arena de Espadas 2D - Hardcore</title>
    <style>
        :root {
            --primary: #00ffcc;
            --basic: #ffff00;
            --fast: #ff00ff;
            --tank: #8888aa;
            --ninja: #440066;
            --boss: #ffd700;
            --bg: #1a1a24;
            --panel: rgba(10, 10, 15, 0.85);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            user-select: none;
        }

        body {
            background-color: #000;
            color: #fff;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            overflow: hidden;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        #gameCanvas {
            background: radial-gradient(circle at center, #2a2a35 0%, var(--bg) 100%);
            box-shadow: 0 0 50px rgba(0,0,0,0.8) inset;
            display: block;
        }

        /* UI Overlays */
        #ui-layer {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            pointer-events: none;
        }

        .hud {
            position: absolute;
            padding: 20px;
            display: flex;
            justify-content: space-between;
            width: 100%;
            z-index: 5;
        }

        .player-stats {
            display: flex;
            flex-direction: column;
            gap: 5px;
        }

        .health-bar-container {
            width: 300px;
            height: 25px;
            background: #222;
            border: 2px solid #555;
            border-radius: 5px;
            overflow: hidden;
            position: relative;
        }

        .health-bar-fill {
            height: 100%;
            background: linear-gradient(90deg, #00cc00, #00ffcc);
            width: 100%;
            transition: width 0.1s, background-color 0.3s;
        }

        .health-text {
            position: absolute;
            width: 100%;
            text-align: center;
            font-size: 14px;
            font-weight: bold;
            line-height: 25px;
            color: white;
            text-shadow: 1px 1px 2px black;
        }

        .phase-counter {
            font-size: 28px;
            font-weight: bold;
            color: #fff;
            text-shadow: 0 0 10px var(--primary);
            text-align: center;
        }

        .enemy-counter {
            font-size: 18px;
            color: #ccc;
            text-align: right;
            width: 250px;
        }

        /* Screens */
        .screen {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: var(--panel);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 10;
            backdrop-filter: blur(5px);
            transition: opacity 0.2s;
        }

        .hidden {
            display: none !important;
            opacity: 0;
            pointer-events: none;
        }

        h1 {
            font-size: 4rem;
            margin-bottom: 10px;
            color: var(--primary);
            text-shadow: 0 0 20px rgba(0, 255, 204, 0.5);
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        h2 {
            font-size: 3rem;
            margin-bottom: 20px;
            color: #ff3366;
            text-shadow: 0 0 15px #ff3366;
        }

        p {
            font-size: 1.2rem;
            margin-bottom: 30px;
            color: #ccc;
            text-align: center;
            max-width: 600px;
            line-height: 1.6;
        }

        .btn {
            padding: 15px 40px;
            font-size: 1.5rem;
            background: transparent;
            color: var(--primary);
            border: 2px solid var(--primary);
            border-radius: 5px;
            cursor: pointer;
            transition: all 0.2s;
            text-transform: uppercase;
            font-weight: bold;
            pointer-events: auto;
        }

        .btn:hover {
            background: var(--primary);
            color: #000;
            box-shadow: 0 0 20px var(--primary);
        }

        .controls-info {
            margin-top: 40px;
            padding: 20px;
            background: rgba(0,0,0,0.5);
            border-radius: 10px;
            border: 1px solid #444;
        }

        .controls-info ul {
            list-style: none;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
        }

        kbd {
            background: #eee;
            color: #000;
            padding: 2px 8px;
            border-radius: 4px;
            font-weight: bold;
            box-shadow: 0 2px 0 #999;
        }

        @keyframes shake {
            0% { transform: translate(1px, 1px) rotate(0deg); }
            20% { transform: translate(-3px, 0px) rotate(1deg); }
            40% { transform: translate(1px, -1px) rotate(1deg); }
            60% { transform: translate(-3px, 1px) rotate(0deg); }
            80% { transform: translate(-1px, -1px) rotate(1deg); }
            100% { transform: translate(1px, -2px) rotate(-1deg); }
        }
        .shake { animation: shake 0.2s; }

        .phase-announcement {
            position: absolute;
            top: 25%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-size: 3rem;
            color: #fff;
            text-shadow: 0 0 20px var(--primary);
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.5s;
            text-align: center;
            background: rgba(0,0,0,0.7);
            padding: 20px 40px;
            border-radius: 15px;
            border: 1px solid var(--primary);
        }

        .show-announcement {
            opacity: 1;
            animation: popIn 3s forwards;
        }

        @keyframes popIn {
            0% { transform: translate(-50%, -50%) scale(0.8); opacity: 0; }
            15% { transform: translate(-50%, -50%) scale(1); opacity: 1; }
            85% { transform: translate(-50%, -50%) scale(1); opacity: 1; }
            100% { transform: translate(-50%, -50%) scale(1.1); opacity: 0; }
        }

        .stats-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 30px;
            background: rgba(0,0,0,0.5);
            padding: 20px;
            border-radius: 10px;
            border: 1px solid var(--boss);
        }
        .stats-grid div {
            text-align: left;
            font-size: 1.2rem;
            color: #fff;
        }
    </style>
</head>
<body>

    <!-- Game Canvas -->
    <canvas id="gameCanvas"></canvas>

    <!-- UI Layer -->
    <div id="ui-layer">
        
        <!-- HUD -->
        <div id="hud" class="hud hidden">
            <div class="player-stats">
                <div class="health-bar-container">
                    <div id="hp-fill" class="health-bar-fill"></div>
                    <div id="hp-text" class="health-text">100 / 100</div>
                </div>
            </div>
            <div id="phase-display" class="phase-counter">Fase 1/8</div>
            <div id="enemy-counter" class="enemy-counter">Inimigos: 0</div>
        </div>

        <!-- Mensagem de Transição de Fase -->
        <div id="phase-announcement" class="phase-announcement">
            <div id="announcement-title">Fase 1</div>
            <div id="announcement-desc" style="font-size: 1.2rem; color: #ffcc00; margin-top: 10px;">Dica...</div>
        </div>

        <!-- Main Menu -->
        <div id="screen-menu" class="screen">
            <h1>Arena Hardcore</h1>
            <p>8 fases brutais. Padrões de IA complexos. Apenas os reflexos perfeitos sobreviverão.</p>
            <button class="btn" onclick="game.start()">Iniciar Jogo</button>
            
            <div class="controls-info">
                <ul>
                    <li><kbd>WASD</kbd> ou <kbd>Setas</kbd> Movimentar</li>
                    <li><kbd>Espaço</kbd> Atacar</li>
                    <li><kbd>E</kbd> Defender / Parry (reduz 50%)</li>
                    <li><kbd>ESC</kbd> Pausar Jogo</li>
                </ul>
            </div>
        </div>

        <!-- Pause Screen -->
        <div id="screen-paused" class="screen hidden">
            <h2 style="color: var(--primary);">JOGO PAUSADO</h2>
            <p>Pressione ESC para retornar à batalha.</p>
        </div>

        <!-- Game Over Screen -->
        <div id="screen-gameover" class="screen hidden">
            <h2>VOCÊ MORREU</h2>
            <p id="gameover-text">A arena cobrou seu preço na Fase X.</p>
            <button class="btn" onclick="game.resetToMenu()">Retornar ao Menu (R)</button>
        </div>

        <!-- Victory Screen -->
        <div id="screen-victory" class="screen hidden">
            <h1 style="color: var(--boss); text-shadow: 0 0 30px var(--boss);">SUPREMACIA</h1>
            <p>Você dominou todos os padrões e venceu a Arena Hardcore.</p>
            
            <div class="stats-grid">
                <div id="stat-time">Tempo: 00:00</div>
                <div id="stat-kills">Abates: 0</div>
                <div id="stat-parries">Parries Perfeitos: 0</div>
                <div id="stat-dmg">Dano Causado: 0</div>
            </div>

            <button class="btn" style="border-color: var(--boss); color: var(--boss);" onclick="game.resetToMenu()">Concluir (R)</button>
        </div>

    </div>

    <script>
        /**
         * ==========================================
         * CORE ENGINE & STATE MANAGEMENT
         * ==========================================
         */
        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');
        const GAME_WIDTH = 1280;
        const GAME_HEIGHT = 720;
        let scale = 1;

        function resize() {
            const windowRatio = window.innerWidth / window.innerHeight;
            const gameRatio = GAME_WIDTH / GAME_HEIGHT;
            scale = windowRatio < gameRatio ? window.innerWidth / GAME_WIDTH : window.innerHeight / GAME_HEIGHT;
            canvas.width = GAME_WIDTH * scale;
            canvas.height = GAME_HEIGHT * scale;
            ctx.scale(scale, scale);
        }
        window.addEventListener('resize', resize);
        resize();

        // STRICT STATE MACHINE (Prevenção de Bugs)
        let gameState = "MENU"; // MENU, GAMEPLAY, PAUSED, GAME_OVER, VICTORY
        let keysPressed = {};

        // Input Listeners (WASD + Arrows Simplesmente unificados no objeto map)
        document.addEventListener('keydown', (e) => {
            let key = e.key.toUpperCase();
            
            // Movement keys always registered to prevent stuck keys
            if (["W","A","S","D","ARROWUP","ARROWDOWN","ARROWLEFT","ARROWRIGHT"].includes(key)) {
                keysPressed[key] = true;
                if (gameState === "GAMEPLAY") e.preventDefault();
            }

            if (gameState === "MENU") {
                if (e.code === "Enter" || e.code === "Space") {
                    game.start();
                }
            } 
            else if (gameState === "GAMEPLAY") {
                if (key === "R") return; // CRÍTICO: R IGNORADO COMPLETAMENTE
                
                if (key === "E" && !game.player.isDead()) game.player.defend();
                if ((key === " " || e.code === "Space") && !game.player.isDead()) {
                    game.player.attack();
                    e.preventDefault();
                }
                if (key === "ESCAPE") {
                    gameState = "PAUSED";
                    document.getElementById('screen-paused').classList.remove('hidden');
                }
            } 
            else if (gameState === "PAUSED") {
                if (key === "ESCAPE") {
                    gameState = "GAMEPLAY";
                    document.getElementById('screen-paused').classList.add('hidden');
                    game.lastTime = performance.now(); // Prevents huge delta time jump
                }
            } 
            else if (gameState === "GAME_OVER" || gameState === "VICTORY") {
                if (key === "R") {
                    game.resetToMenu();
                }
            }
        });

        document.addEventListener('keyup', (e) => {
            let key = e.key.toUpperCase();
            delete keysPressed[key];
        });

        // Utils
        const Utils = {
            dist: (x1, y1, x2, y2) => Math.sqrt((x2-x1)**2 + (y2-y1)**2),
            clamp: (val, min, max) => Math.max(min, Math.min(max, val)),
            rectIntersect: (r1, r2) => !(r2.x > r1.x + r1.w || r2.x + r2.w < r1.x || r2.y > r1.y + r1.h || r2.y + r2.h < r1.y),
            random: (min, max) => Math.random() * (max - min) + min
        };

        /**
         * ==========================================
         * VISUAL EFFECTS
         * ==========================================
         */
        class Particle {
            constructor(x, y, color, speed, size, life) {
                this.x = x; this.y = y;
                this.vx = (Math.random() - 0.5) * speed;
                this.vy = (Math.random() - 0.5) * speed;
                this.color = color; this.size = size;
                this.life = life; this.maxLife = life;
            }
            update(dt) { this.x += this.vx * dt; this.y += this.vy * dt; this.life -= dt; }
            draw(ctx) {
                ctx.globalAlpha = Math.max(0, this.life / this.maxLife);
                ctx.fillStyle = this.color;
                ctx.beginPath(); ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2); ctx.fill();
                ctx.globalAlpha = 1;
            }
        }

        class FloatingText {
            constructor(x, y, text, color, isCrit = false) {
                this.x = x; this.y = y; this.text = text; this.color = color;
                this.life = 0.8; this.vy = -40; this.isCrit = isCrit;
            }
            update(dt) { this.y += this.vy * dt; this.life -= dt; }
            draw(ctx) {
                ctx.globalAlpha = Math.max(0, this.life);
                ctx.fillStyle = this.color;
                ctx.font = this.isCrit ? "bold 26px Arial" : "bold 18px Arial";
                ctx.textAlign = "center";
                ctx.strokeStyle = "black"; ctx.lineWidth = 3;
                ctx.strokeText(this.text, this.x, this.y);
                ctx.fillText(this.text, this.x, this.y);
                ctx.globalAlpha = 1;
            }
        }

        /**
         * ==========================================
         * ENTITIES
         * ==========================================
         */
        class Entity {
            constructor(x, y, w, h, hp) {
                this.x = x; this.y = y; this.w = w; this.h = h;
                this.hp = hp; this.maxHp = hp;
                this.vx = 0; this.vy = 0;
                this.dirX = 1; this.dirY = 0;
                this.state = 'IDLE'; 
                this.stateTimer = 0;
            }
            isDead() { return this.state === 'DEAD'; }
            applyPhysics(dt) {
                this.vx *= 0.85; this.vy *= 0.85; // friction
                this.x = Utils.clamp(this.x + this.vx * dt, 0, GAME_WIDTH - this.w);
                this.y = Utils.clamp(this.y + this.vy * dt, 0, GAME_HEIGHT - this.h);
            }
        }

        class Player extends Entity {
            constructor() {
                super(GAME_WIDTH / 2, GAME_HEIGHT / 2, 40, 40, 100);
                this.speed = 300; // pixels por segundo (aprox 5.0 px/frame)
                this.color = 'var(--primary)';
                this.attackCooldown = 0;
                this.defendCooldown = 0;
                this.combo = 0;
                this.comboTimer = 0;
            }

            update(dt) {
                if (this.isDead()) return;
                this.stateTimer += dt;
                if (this.attackCooldown > 0) this.attackCooldown -= dt;
                if (this.defendCooldown > 0) this.defendCooldown -= dt;
                if (this.comboTimer > 0) {
                    this.comboTimer -= dt;
                    if (this.comboTimer <= 0) this.combo = 0;
                }

                // Handle States
                if (this.state === 'HURT') {
                    if (this.stateTimer > 0.2) this.state = 'IDLE';
                } else if (this.state === 'ATTACK') {
                    if (this.stateTimer > 0.25) this.state = 'IDLE';
                } else if (this.state === 'DEFEND') {
                    if (this.stateTimer > 0.3) {
                        this.state = 'IDLE';
                        this.defendCooldown = 0.3; // E MUST cool down
                    }
                } else {
                    // Read movement from Map (WASD and Arrows combined)
                    let dx = 0, dy = 0;
                    if (keysPressed["W"] || keysPressed["ARROWUP"]) dy -= 1;
                    if (keysPressed["S"] || keysPressed["ARROWDOWN"]) dy += 1;
                    if (keysPressed["A"] || keysPressed["ARROWLEFT"]) dx -= 1;
                    if (keysPressed["D"] || keysPressed["ARROWRIGHT"]) dx += 1;

                    if (dx !== 0 || dy !== 0) {
                        let len = Math.sqrt(dx*dx + dy*dy);
                        this.x += (dx/len) * this.speed * dt;
                        this.y += (dy/len) * this.speed * dt;
                        if (dx !== 0) this.dirX = dx > 0 ? 1 : -1;
                        if (dy !== 0) this.dirY = dy > 0 ? 1 : -1;
                        this.state = 'RUN';
                    } else {
                        this.state = 'IDLE';
                    }
                }

                this.applyPhysics(dt);
                this.updateUI();
            }

            attack() {
                if (this.attackCooldown > 0 || this.state === 'DEFEND') return;
                this.state = 'ATTACK';
                this.stateTimer = 0;
                this.attackCooldown = 0.5; // Exactly 0.5s requirement
                
                this.combo++;
                this.comboTimer = 1.0;
                let isCombo = this.combo % 3 === 0;

                // Lunge
                this.vx = this.dirX * 250;
                
                // Hitbox calculations
                let hitWidth = 70, hitRange = 90;
                let hx = this.dirX > 0 ? this.x + this.w : this.x - hitRange;
                let hy = this.y - (hitWidth - this.h)/2;
                let hitbox = { x: hx, y: hy, w: hitRange, h: hitWidth };

                // Visual FX
                for(let i=0; i<6; i++) {
                    game.particles.push(new Particle(hx + Math.random()*hitRange, hy + Math.random()*hitWidth, isCombo ? '#fff' : this.color, 100, 2, 0.2));
                }

                // Apply damage
                let baseDmg = Math.floor(Utils.random(10, 15));
                if (isCombo) baseDmg = Math.floor(baseDmg * 1.5); // Combo bônus opcional

                game.enemies.forEach(e => {
                    if (!e.isDead() && Utils.rectIntersect(hitbox, e)) {
                        e.takeDamage(baseDmg, this.x, this.y, isCombo);
                        game.stats.dmg += baseDmg;
                    }
                });
            }

            defend() {
                if (this.defendCooldown > 0 || this.state === 'ATTACK' || this.state === 'DEFEND') return;
                this.state = 'DEFEND';
                this.stateTimer = 0;
                this.vx = 0; this.vy = 0;
            }

            takeDamage(amount, sourceX, sourceY, canBeParried = true) {
                if (this.isDead()) return;

                let dmg = amount;
                let parried = false;

                if (this.state === 'DEFEND') {
                    // Timing perfeito (< 0.15s) = Parry
                    if (this.stateTimer <= 0.15 && canBeParried) {
                        parried = true;
                        dmg = 0;
                        game.stats.parries++;
                        game.spawnFloatingText(this.x+20, this.y, "PARRY!", "#0ff", true);
                        game.screenShake(10);
                        
                        // Reflete duplo
                        game.enemies.forEach(e => {
                            if (Utils.dist(this.x, this.y, e.x, e.y) < 150) e.takeDamage(amount * 2, this.x, this.y, true);
                        });
                        for(let i=0; i<15; i++) game.particles.push(new Particle(this.x+20, this.y+20, '#0ff', 300, 3, 0.4));
                    } else {
                        // Defesa normal (50%)
                        dmg = Math.floor(amount * 0.5);
                        game.spawnFloatingText(this.x+20, this.y, "Defesa", "#ccc");
                    }
                }

                if (!parried && dmg > 0) {
                    this.hp -= dmg;
                    this.state = 'HURT';
                    this.stateTimer = 0;
                    
                    let angle = Math.atan2(this.y - sourceY, this.x - sourceX);
                    this.vx = Math.cos(angle) * 300;
                    this.vy = Math.sin(angle) * 300;

                    game.spawnFloatingText(this.x+20, this.y, `-${dmg}`, "#f33", true);
                    game.screenShake(5);
                    document.body.classList.add('shake');
                    setTimeout(() => document.body.classList.remove('shake'), 200);

                    if (this.hp <= 0) {
                        this.hp = 0;
                        this.state = 'DEAD';
                        game.triggerGameOver();
                    }
                }
            }

            updateUI() {
                let pct = Math.max(0, this.hp / this.maxHp);
                let fill = document.getElementById('hp-fill');
                fill.style.width = `${pct * 100}%`;
                
                // RGB progressivo
                if (pct > 0.6) fill.style.background = 'linear-gradient(90deg, #00cc00, #00ffcc)';
                else if (pct > 0.3) fill.style.background = 'linear-gradient(90deg, #ccaa00, #ffff00)';
                else fill.style.background = 'linear-gradient(90deg, #cc0000, #ff3333)';
                
                document.getElementById('hp-text').innerText = `${Math.floor(this.hp)} / ${this.maxHp}`;
            }

            draw(ctx) {
                // Shadow
                ctx.fillStyle = 'rgba(0,0,0,0.5)';
                ctx.beginPath(); ctx.ellipse(this.x + 20, this.y + 40, 20, 10, 0, 0, Math.PI*2); ctx.fill();

                // Body
                ctx.fillStyle = this.state === 'HURT' ? '#ffaaaa' : this.color;
                ctx.fillRect(this.x, this.y, this.w, this.h);

                // Eyes
                ctx.fillStyle = '#000';
                let ex = this.dirX > 0 ? 25 : 5;
                ctx.fillRect(this.x + ex, this.y + 10, 5, 5);
                ctx.fillRect(this.x + ex, this.y + 20, 5, 5);

                // Shield
                if (this.state === 'DEFEND') {
                    ctx.strokeStyle = this.stateTimer < 0.15 ? '#fff' : '#0af';
                    ctx.lineWidth = 4;
                    ctx.beginPath(); ctx.arc(this.x+20, this.y+20, 30, 0, Math.PI*2); ctx.stroke();
                    ctx.fillStyle = 'rgba(0, 170, 255, 0.2)'; ctx.fill();
                }

                // Attack Anim
                if (this.state === 'ATTACK') {
                    ctx.save();
                    ctx.translate(this.x+20, this.y+20);
                    ctx.strokeStyle = this.combo%3===0 ? '#fff' : this.color;
                    ctx.lineWidth = 8;
                    ctx.beginPath();
                    let sA = this.dirX>0 ? -Math.PI/2 : Math.PI/2;
                    let eA = this.dirX>0 ? Math.PI/2 : 3*Math.PI/2;
                    let curr = sA + (eA - sA) * (this.stateTimer/0.25);
                    ctx.arc(0, 0, 45, sA, curr, this.dirX < 0);
                    ctx.stroke();
                    ctx.restore();
                }
            }
        }

        class Enemy extends Entity {
            constructor(type, x, y, hpBase) {
                super(x, y, 40, 40, hpBase);
                this.type = type;
                this.aiTimer = 0;
                this.attackCooldown = 0;
                this.regenTimer = 0;
                
                // Configurar Perfis Hardcore
                if(type === 'basic') { this.color='var(--basic)'; this.speed=150; this.maxAttackCD=2.2; this.w=40; this.h=40; }
                if(type === 'fast')  { this.color='var(--fast)'; this.speed=270; this.maxAttackCD=0.6; this.w=35; this.h=35; }
                if(type === 'tank')  { this.color='var(--tank)'; this.speed=132; this.maxAttackCD=2.8; this.w=50; this.h=50; }
                if(type === 'ninja') { this.color='var(--ninja)'; this.speed=210; this.maxAttackCD=0.5; this.w=35; this.h=35; }
                if(type === 'boss')  { this.color='var(--boss)'; this.speed=120; this.maxAttackCD=2.2; this.w=60; this.h=60; }

                if (game.currentPhase === 5 && type === 'tank') this.speed = 100; // Ajuste fino Fase 6

                this.bossPhase = 1;
                this.multiHitCount = 0;
                this.isBlocking = false;
            }

            update(dt) {
                if (this.isDead() || game.player.isDead()) return;

                this.stateTimer += dt;
                this.aiTimer += dt;
                if (this.attackCooldown > 0) this.attackCooldown -= dt;

                // Regeneração (Tanque e Boss)
                if (this.type === 'tank' || this.type === 'boss') {
                    this.regenTimer += dt;
                    if (this.regenTimer >= 30) {
                        this.regenTimer = 0;
                        let amount = 15;
                        this.hp = Math.min(this.maxHp, this.hp + amount);
                        game.spawnFloatingText(this.x+this.w/2, this.y, `+${amount} HP`, "#0f0");
                    }
                    if (this.type === 'tank') {
                        this.isBlocking = this.hp < this.maxHp * 0.5;
                    }
                }

                if (this.state === 'HURT') {
                    if (this.stateTimer > 0.2) this.state = 'IDLE';
                } 
                else if (this.state === 'ATTACK_WINDUP') {
                    if (this.stateTimer > 0.4) this.executeAttack();
                } 
                else if (this.state === 'ATTACK_REC') {
                    if (this.stateTimer > 0.5) {
                        this.state = 'IDLE';
                        // Boss / Tank multi-hit continuation
                        if (this.multiHitCount > 0) {
                            this.state = 'ATTACK_WINDUP';
                            this.stateTimer = 0.2; // faster windup for combo
                        }
                    }
                } 
                else {
                    this.processAILogic(dt);
                }

                this.applyPhysics(dt);
            }

            processAILogic(dt) {
                let p = game.player;
                let dist = Utils.dist(this.x, this.y, p.x, p.y);
                
                // Avoid grouping (repel from other enemies)
                game.enemies.forEach(other => {
                    if (other !== this && !other.isDead()) {
                        let d = Utils.dist(this.x, this.y, other.x, other.y);
                        if (d < 50 && d > 0) {
                            this.x += (this.x - other.x) / d * 2;
                            this.y += (this.y - other.y) / d * 2;
                        }
                    }
                });

                // Range Check (Minimum 400px detection for hardcore requirement)
                if (dist > 800) { this.state = 'IDLE'; return; }

                this.state = 'RUN';
                this.dirX = (p.x - this.x) > 0 ? 1 : -1;

                // ==========================================
                // IA PROFILE 1: BÁSICO (Movimento Retilíneo)
                // ==========================================
                if (this.type === 'basic') {
                    if (dist < 80 && this.attackCooldown <= 0) {
                        this.startAttack(1);
                    } else if (dist > 70) {
                        // Linha reta, foca no eixo mais distante
                        if (Math.abs(p.x - this.x) > Math.abs(p.y - this.y)) {
                            this.x += this.dirX * this.speed * dt;
                        } else {
                            this.y += (p.y > this.y ? 1 : -1) * this.speed * dt;
                        }
                    }
                }
                
                // ==========================================
                // IA PROFILE 2: RÁPIDO/PREDADOR (Antecipação)
                // ==========================================
                else if (this.type === 'fast') {
                    let activeSpeed = this.hp < this.maxHp*0.4 ? this.speed * 1.2 : this.speed;
                    
                    if (dist < 60 && this.attackCooldown <= 0) {
                        this.startAttack(p.state === 'IDLE' ? 3 : 1); // 3 hits se jogador parado
                    } else if (dist > 50) {
                        // Predict position
                        let targetX = p.x + (p.state==='RUN' ? p.dirX * 60 : 0);
                        let targetY = p.y + (p.state==='RUN' ? p.dirY * 60 : 0);
                        
                        let angle = Math.atan2(targetY - this.y, targetX - this.x);
                        // Erratic jump
                        if (this.aiTimer > 5) {
                            this.aiTimer = 0;
                            this.vx = Math.cos(angle) * 800;
                            this.vy = Math.sin(angle) * 800;
                        } else {
                            this.x += Math.cos(angle) * activeSpeed * dt;
                            this.y += Math.sin(angle) * activeSpeed * dt;
                        }
                    }
                    if (p.state === 'DEFEND') this.aiTimer -= dt * 2; // confuso
                }
                
                // ==========================================
                // IA PROFILE 3: TANK (Lento, Multi-hit)
                // ==========================================
                else if (this.type === 'tank') {
                    if (dist < 90 && this.attackCooldown <= 0) {
                        this.startAttack(this.aiTimer > 12 ? 3 : 1);
                        if (this.aiTimer > 12) this.aiTimer = 0; // reseta especial
                    } else if (dist > 80) {
                        let angle = Math.atan2(p.y - this.y, p.x - this.x);
                        this.x += Math.cos(angle) * this.speed * dt;
                        this.y += Math.sin(angle) * this.speed * dt;
                    }
                }
                
                // ==========================================
                // IA PROFILE 4: NINJA (Teletransporte)
                // ==========================================
                else if (this.type === 'ninja') {
                    if (this.aiTimer > 1.5) {
                        this.aiTimer = 0;
                        // FX before
                        for(let i=0; i<15; i++) game.particles.push(new Particle(this.x+20, this.y+20, this.color, 200, 3, 0.4));
                        
                        // TP Logic: behind if attacking/idle, opposite if defending
                        let offset = p.state === 'DEFEND' ? 60 : -60;
                        this.x = p.x + (p.dirX * offset);
                        this.y = p.y;
                        this.x = Utils.clamp(this.x, 0, GAME_WIDTH - this.w);
                        
                        // FX after
                        for(let i=0; i<15; i++) game.particles.push(new Particle(this.x+20, this.y+20, this.color, 200, 3, 0.4));
                        this.startAttack(1); // ataca imediato
                    } else {
                        // Spiral hover
                        if (dist > 70) {
                            let angle = Math.atan2(p.y - this.y, p.x - this.x) + 0.5; // offset angle
                            this.x += Math.cos(angle) * this.speed * dt;
                            this.y += Math.sin(angle) * this.speed * dt;
                        }
                    }
                }
                
                // ==========================================
                // IA PROFILE 5: BOSS SUPREMO
                // ==========================================
                else if (this.type === 'boss') {
                    // Update Phase logic
                    if (this.hp < 40) this.bossPhase = 3;
                    else if (this.hp < 80) this.bossPhase = 2;

                    let activeSpeed = this.bossPhase === 1 ? 120 : (this.bossPhase === 2 ? 210 : 270);
                    this.isBlocking = this.bossPhase === 3;

                    if (this.bossPhase === 3 && this.aiTimer > 8) {
                        this.aiTimer = 0;
                        this.startAttack(5); // Berserk special
                    } 
                    else if (dist < 100 && this.attackCooldown <= 0) {
                        this.startAttack(1);
                    } 
                    else if (dist > 90) {
                        let targetX = p.x, targetY = p.y;
                        if (this.bossPhase >= 2) { // Anticipate
                            targetX += p.dirX * 50; targetY += p.dirY * 50;
                        }
                        let angle = Math.atan2(targetY - this.y, targetX - this.x);
                        this.x += Math.cos(angle) * activeSpeed * dt;
                        this.y += Math.sin(angle) * activeSpeed * dt;
                    }
                }
            }

            startAttack(hits) {
                this.state = 'ATTACK_WINDUP';
                this.stateTimer = 0;
                this.vx = 0; this.vy = 0;
                this.multiHitCount = hits - 1; // 1 current + remaining
                this.attackCooldown = this.maxAttackCD;
            }

            executeAttack() {
                this.state = 'ATTACK_REC';
                this.stateTimer = 0;
                
                this.vx = this.dirX * 200; // lunge

                // Determine Damage based on type & multiplier
                let baseDmg = 0;
                let isNinjaTriple = false;

                if (this.type === 'basic') baseDmg = Utils.random(10, 12);
                else if (this.type === 'fast') baseDmg = Utils.random(10, 14); // Atualizado para fase 4+
                else if (this.type === 'tank') baseDmg = this.multiHitCount === 0 && this.maxAttackCD === 2.8 ? 18 : Utils.random(16, 20); // Last hit of special is stronger
                else if (this.type === 'ninja') { baseDmg = Utils.random(13, 17); isNinjaTriple = true; }
                else if (this.type === 'boss') baseDmg = Utils.random(15, 18);

                let phaseMult = 1 + (game.currentPhase * 0.1);
                baseDmg = Math.floor(baseDmg * phaseMult);

                let attackRange = this.w + 30;
                let dist = Utils.dist(this.x, this.y, game.player.x, game.player.y);
                
                // Frontal check (Ninja attacks 3 directions, so skip frontal check)
                let playerInFront = isNinjaTriple || ((this.dirX > 0 && game.player.x > this.x - 20) || (this.dirX < 0 && game.player.x < this.x + this.w + 20));

                if (dist < attackRange && playerInFront) {
                    game.player.takeDamage(baseDmg, this.x, this.y);
                }

                if (this.multiHitCount > 0) this.multiHitCount--;
            }

            takeDamage(amount, sourceX, sourceY, isCrit = false) {
                if (this.isDead()) return;

                let dmg = amount;
                if (this.isBlocking) {
                    dmg = Math.floor(amount * 0.6); // 40% reduction
                    game.spawnFloatingText(this.x+this.w/2, this.y, "Bloqueado", "#888");
                }
                if (this.type === 'ninja' && isCrit) {
                    dmg *= 2; // Fraqueza: Parry reflete 2x
                }

                this.hp -= dmg;
                this.state = 'HURT';
                this.stateTimer = 0;
                
                let angle = Math.atan2(this.y - sourceY, this.x - sourceX);
                this.vx = Math.cos(angle) * (this.type === 'boss' || this.type === 'tank' ? 50 : 150);
                this.vy = Math.sin(angle) * (this.type === 'boss' || this.type === 'tank' ? 50 : 150);

                game.spawnFloatingText(this.x+this.w/2, this.y, `-${dmg}`, isCrit ? '#ff00ff' : '#fff', isCrit);
                
                for(let i=0; i<8; i++) game.particles.push(new Particle(this.x+this.w/2, this.y+this.h/2, this.color, 150, 4, 0.3));

                if (this.hp <= 0) {
                    this.hp = 0;
                    this.state = 'DEAD';
                    game.stats.kills++;
                }
            }

            draw(ctx) {
                if (this.isDead()) return;

                // Shadow
                ctx.fillStyle = 'rgba(0,0,0,0.5)';
                ctx.beginPath(); ctx.ellipse(this.x + this.w/2, this.y + this.h, this.w/2, 10, 0, 0, Math.PI*2); ctx.fill();

                // Flash Logic
                ctx.fillStyle = this.color;
                if (this.state === 'HURT') ctx.fillStyle = '#fff';
                if (this.state === 'ATTACK_WINDUP' && this.stateTimer % 0.1 < 0.05) ctx.fillStyle = '#fff';

                ctx.fillRect(this.x, this.y, this.w, this.h);

                // Boss Phases Aura
                if (this.type === 'boss') {
                    ctx.strokeStyle = this.bossPhase === 3 ? '#f00' : (this.bossPhase === 2 ? '#f0f' : 'transparent');
                    ctx.lineWidth = 2;
                    ctx.strokeRect(this.x-2, this.y-2, this.w+4, this.h+4);
                }

                // Eyes
                ctx.fillStyle = '#000';
                let ex = this.dirX > 0 ? this.w*0.6 : this.w*0.1;
                ctx.fillRect(this.x + ex, this.y + this.h*0.2, this.w*0.15, this.w*0.15);
                ctx.fillRect(this.x + ex, this.y + this.h*0.5, this.w*0.15, this.w*0.15);

                // Tank Block Shield
                if (this.isBlocking) {
                    ctx.strokeStyle = 'rgba(136, 136, 170, 0.5)';
                    ctx.lineWidth = 3;
                    ctx.strokeRect(this.x-5, this.y-5, this.w+10, this.h+10);
                }

                // HP Bar
                if (this.hp < this.maxHp) {
                    ctx.fillStyle = '#222'; ctx.fillRect(this.x, this.y - 10, this.w, 5);
                    ctx.fillStyle = '#f00'; ctx.fillRect(this.x, this.y - 10, this.w * (this.hp / this.maxHp), 5);
                }

                // Attack Vis
                if (this.state === 'ATTACK_REC' && this.stateTimer < 0.15) {
                    ctx.fillStyle = 'rgba(255, 255, 255, 0.8)';
                    if (this.type === 'ninja') {
                        // 3 hits visuais
                        ctx.fillRect(this.x-10, this.y-10, this.w+20, 10);
                        ctx.fillRect(this.x-10, this.y+this.h, this.w+20, 10);
                        if (this.dirX > 0) ctx.fillRect(this.x+this.w, this.y, 20, this.h);
                        else ctx.fillRect(this.x-20, this.y, 20, this.h);
                    } else {
                        if (this.dirX > 0) ctx.fillRect(this.x + this.w, this.y + 10, 30, 20);
                        else ctx.fillRect(this.x - 30, this.y + 10, 30, 20);
                    }
                }
            }
        }

        /**
         * ==========================================
         * GAME MANAGER
         * ==========================================
         */
        const game = {
            player: null,
            enemies: [],
            particles: [],
            floatingTexts: [],
            currentPhase: 1,
            shakeTime: 0,
            lastTime: 0,
            
            stats: { startTime: 0, kills: 0, parries: 0, dmg: 0 },

            phasesConfig: [
                { id: 1, pHP: 120, title: "Fase 1: Tutorial", desc: "Padrão: linha reta. Ataque quando ele parar.", spawn: () => [new Enemy('basic', 1000, 360, 35)] },
                { id: 2, pHP: 110, title: "Fase 2: Espaço", desc: "Controle a distância. Mantenha eles separados.", spawn: () => [new Enemy('basic', 900, 200, 35), new Enemy('basic', 900, 500, 35)] },
                { id: 3, pHP: 100, title: "Fase 3: O Predador", desc: "Rosa antecipa seus movimentos. Cuidado!", spawn: () => [new Enemy('basic', 900, 200, 35), new Enemy('fast', 1000, 500, 28)] },
                { id: 4, pHP: 95, title: "Fase 4: Caos", desc: "Mantenha um sempre entre você e o outro.", spawn: () => [new Enemy('fast', 300, 100, 32), new Enemy('fast', 1000, 600, 32)] },
                { id: 5, pHP: 100, title: "Fase 5: O Tanque", desc: "Ataques lentos mas regenera vida. Acumule dano.", spawn: () => [new Enemy('tank', 1000, 360, 75)] },
                { id: 6, pHP: 90, title: "Fase 6: O Inferno", desc: "Isole o Tanque dos Rápidos.", spawn: () => [new Enemy('tank', 900, 360, 75), new Enemy('fast', 400, 100, 34), new Enemy('fast', 400, 600, 34)] },
                { id: 7, pHP: 100, title: "Fase 7: O Fantasma", desc: "Ele teletransporta para suas costas. Reaja!", spawn: () => [new Enemy('ninja', 1000, 360, 28)] },
                { id: 8, pHP: 100, title: "Supremacia", desc: "Ele aprende. Mude sua estratégia a cada 40 de HP.", spawn: () => [new Enemy('boss', 1000, 360, 120)] }
            ],

            start() {
                gameState = "GAMEPLAY";
                this.stats = { startTime: Date.now(), kills: 0, parries: 0, dmg: 0 };
                document.getElementById('screen-menu').classList.add('hidden');
                document.getElementById('hud').classList.remove('hidden');
                this.player = new Player();
                this.startPhase(1);
                
                if (!this.lastTime) {
                    this.lastTime = performance.now();
                    requestAnimationFrame((ts) => this.loop(ts));
                }
            },

            resetToMenu() {
                gameState = "MENU";
                document.getElementById('screen-gameover').classList.add('hidden');
                document.getElementById('screen-victory').classList.add('hidden');
                document.getElementById('hud').classList.add('hidden');
                document.getElementById('screen-menu').classList.remove('hidden');
            },

            triggerGameOver() {
                gameState = "GAME_OVER";
                document.getElementById('gameover-text').innerText = `A arena cobrou seu preço na Fase ${this.currentPhase}.`;
                setTimeout(() => { document.getElementById('screen-gameover').classList.remove('hidden'); }, 1000);
            },

            winGame() {
                gameState = "VICTORY";
                document.getElementById('screen-victory').classList.remove('hidden');
                document.getElementById('hud').classList.add('hidden');
                
                let time = Math.floor((Date.now() - this.stats.startTime)/1000);
                document.getElementById('stat-time').innerText = `Tempo Total: ${Math.floor(time/60).toString().padStart(2,'0')}:${(time%60).toString().padStart(2,'0')}`;
                document.getElementById('stat-kills').innerText = `Abates Totais: ${this.stats.kills}`;
                document.getElementById('stat-parries').innerText = `Parries Perfeitos: ${this.stats.parries}`;
                document.getElementById('stat-dmg').innerText = `Dano Causado: ${this.stats.dmg}`;
            },

            startPhase(pNum) {
                this.currentPhase = pNum;
                let pData = this.phasesConfig[pNum - 1];
                
                this.enemies = [];
                this.particles = [];
                this.floatingTexts = [];
                
                this.player.maxHp = pData.pHP;
                this.player.hp = pData.pHP;
                this.player.x = 200;
                this.player.y = GAME_HEIGHT / 2;
                this.player.state = 'IDLE';
                keysPressed = {}; // Clean inputs
                
                document.getElementById('phase-display').innerText = `Fase ${pNum}/8`;

                // Announcement
                document.getElementById('announcement-title').innerText = pData.title;
                document.getElementById('announcement-desc').innerText = pData.desc;
                const ann = document.getElementById('phase-announcement');
                ann.classList.remove('show-announcement');
                void ann.offsetWidth; // reflow
                ann.classList.add('show-announcement');

                // Spawn with delay
                setTimeout(() => {
                    if (gameState === "GAMEPLAY" || gameState === "PAUSED") {
                        this.enemies = pData.spawn();
                        this.enemies.forEach(e => {
                            for(let i=0; i<30; i++) this.particles.push(new Particle(e.x+20, e.y+20, e.color, 300, 3, 0.6));
                        });
                        this.updateEnemyCounter();
                    }
                }, 1500);
            },

            updateEnemyCounter() {
                let count = this.enemies.filter(e => !e.isDead()).length;
                document.getElementById('enemy-counter').innerText = `Inimigos restantes: ${count}`;
            },

            screenShake(frames) { this.shakeTime = frames; },
            spawnFloatingText(x, y, t, c, crit=false) { this.floatingTexts.push(new FloatingText(x, y, t, c, crit)); },

            update(dt) {
                if (gameState !== "GAMEPLAY") return;

                this.player.update(dt);

                let aliveCount = 0;
                this.enemies.forEach(e => {
                    e.update(dt);
                    if (!e.isDead()) aliveCount++;
                });
                
                // Update counter on the fly if needed, but better to just set it on kill inside takeDamage
                document.getElementById('enemy-counter').innerText = `Inimigos restantes: ${aliveCount}`;

                // Next Phase logic
                if (aliveCount === 0 && this.enemies.length > 0) {
                    this.enemies = []; 
                    if (this.currentPhase < 8) this.startPhase(this.currentPhase + 1);
                    else setTimeout(() => this.winGame(), 2000);
                }

                // Cleanup FX
                for (let i = this.particles.length - 1; i >= 0; i--) {
                    this.particles[i].update(dt);
                    if (this.particles[i].life <= 0) this.particles.splice(i, 1);
                }
                for (let i = this.floatingTexts.length - 1; i >= 0; i--) {
                    this.floatingTexts[i].update(dt);
                    if (this.floatingTexts[i].life <= 0) this.floatingTexts.splice(i, 1);
                }
            },

            draw() {
                ctx.clearRect(0, 0, GAME_WIDTH, GAME_HEIGHT);

                // BG Grid Setup
                ctx.strokeStyle = 'rgba(255, 255, 255, 0.05)';
                ctx.lineWidth = 1;
                for(let i=0; i<GAME_WIDTH; i+=100) { ctx.beginPath(); ctx.moveTo(i, 0); ctx.lineTo(i, GAME_HEIGHT); ctx.stroke(); }
                for(let i=0; i<GAME_HEIGHT; i+=100) { ctx.beginPath(); ctx.moveTo(0, i); ctx.lineTo(GAME_WIDTH, i); ctx.stroke(); }

                ctx.save();
                if (this.shakeTime > 0) {
                    ctx.translate((Math.random()-0.5)*12, (Math.random()-0.5)*12);
                    this.shakeTime--;
                }

                // Sorting to draw properly
                let renderList = [this.player, ...this.enemies].sort((a, b) => (a.y+a.h) - (b.y+b.h));
                renderList.forEach(ent => {
                    if (ent.isDead() && !ent.isPlayer) {
                        ctx.globalAlpha = 0.2;
                        ctx.save(); ctx.translate(ent.x + ent.w/2, ent.y + ent.h); ctx.scale(1, 0.2); 
                        ent.x = -ent.w/2; ent.y = -ent.h; ent.draw(ctx);
                        ctx.restore(); ctx.globalAlpha = 1;
                        ent.x += ent.w/2; ent.y += ent.h; // restore
                    } else if (!ent.isDead()) {
                        ent.draw(ctx);
                    }
                });

                this.particles.forEach(p => p.draw(ctx));
                this.floatingTexts.forEach(t => t.draw(ctx));

                // Darkness Phase 7
                if (this.currentPhase === 7 && gameState === 'GAMEPLAY') {
                    let p = this.player;
                    let grad = ctx.createRadialGradient(p.x+20, p.y+20, 150, p.x+20, p.y+20, 600);
                    grad.addColorStop(0, 'rgba(0,0,0,0)');
                    grad.addColorStop(1, 'rgba(0,0,0,0.98)');
                    ctx.fillStyle = grad;
                    ctx.fillRect(-100, -100, GAME_WIDTH+200, GAME_HEIGHT+200);
                }

                if (this.player.state === 'HURT') {
                    ctx.fillStyle = 'rgba(255, 0, 0, 0.25)';
                    ctx.fillRect(0, 0, GAME_WIDTH, GAME_HEIGHT);
                }

                ctx.restore();
            },

            loop(timestamp) {
                let dt = (timestamp - this.lastTime) / 1000;
                this.lastTime = timestamp;
                
                if (dt > 0.1) dt = 0.1; // Limit tab inactive huge jump

                this.update(dt);
                this.draw();

                requestAnimationFrame((ts) => this.loop(ts));
            }
        };

    </script>
